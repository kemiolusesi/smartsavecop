# Public Supabase values for local development.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Set to true ONLY for local dev to bypass admin login. Never set in production.
NEXT_PUBLIC_ADMIN_DEV_BYPASS=false

# Existing development-only dashboard preview bypass.
NEXT_PUBLIC_DEV_BYPASS=false

# App integrations.
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ADMIN_EMAIL=
